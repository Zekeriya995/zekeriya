# ═══════════════════════════════════════════════════════════════
#  NEXUS PRO V10 — Proxy Server Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` (cp .env.example .env) and fill in the values.
# Never commit `.env` — it is git-ignored.

# ─── Server ────────────────────────────────────────────────────
# Port the Express proxy listens on locally. Nginx in front will
# proxy_pass https://shamcyrpto.com/api/* → http://127.0.0.1:3000/api/*
PORT=3000

# Set to "true" when running behind nginx / Cloudflare so
# express-rate-limit keys by the real client IP from X-Forwarded-For.
TRUST_PROXY=true

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call /api/*.
# A literal `*` is rejected by code — always list explicit origins.
ALLOWED_ORIGINS=https://shamcyrpto.com,https://www.shamcyrpto.com

# ─── Telegram Notifications (optional) ─────────────────────────
# Get a bot token from @BotFather, then talk to your bot once and
# call https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id.
TG_BOT_TOKEN=
TG_CHAT_ID=

# Optional shared secret for /notify. If set, the PWA must include
# the same value as `X-Notify-Secret` header. Leave empty to allow
# unauthenticated callers (rate-limit + CORS still apply).
NEXUS_NOTIFY_SECRET=

# ─── Web Push Notifications (optional) ──────────────────────────
# Generate a fresh pair on the VPS with:
#   npx web-push generate-vapid-keys
# Then paste the printed values here. The PUBLIC key is also baked
# into the PWA (browsers fetch it from /api/push/public-key when
# subscribing, so it's not actually a secret), and the PRIVATE key
# stays on the server. VAPID_EMAIL is the contact address Mozilla /
# Apple / Google push services email if a delivery problem hits a
# huge volume of users — any address you can read works.
# Leaving these blank disables the /api/push/* endpoints; the rest
# of the proxy keeps working unchanged.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@shamcyrpto.com

# ─── Scanner Remediation Flags ──────────────────────────────────
# Each flag gates one scanner fix scheduled in SCANNER_AUDIT_2026_05_15.md.
# Defaults below match the eventual rollout (true = fix active). Toggle to
# `false` for instant rollback without a redeploy (pm2 restart required).
# Flags are DOCUMENTED here in Phase 0; the wiring that READS each flag
# ships in its respective phase.
#
# Phase 1.1 — Port P&D detector to server (audit §2.1 / qualification #7)
SCANNER_SERVER_PD_ENABLED=true
#
# Phase 1.2 — Manipulation HIGH hard-caps tier at STRONG (audit §2.4)
SCANNER_MANIP_HARD_CAP=true
#
# Phase 1.3 — Smart ULTRA cooldown bypass on score delta >= 30 (audit §6 P1.3)
SCANNER_ULTRA_DELTA_PUSH=true
#
# Phase 2.A.1 — Unified scoring rules registry (audit §6 P2.A.1)
SCANNER_UNIFIED_RULES=false
#
# Phase 2.A.2 — PWA consumes server-side signals (audit §6 P2.A.2)
SCANNER_PWA_USES_SERVER_SIGNALS=false
#
# Phase 2.A.4 — Server-side ATR-aware SL/TP (audit §2.5)
SCANNER_SERVER_ATR_ZONES=true
#
# Phase 3.1 — Per-tag win-rate tracking (audit §6 P3.1)
SCANNER_TAG_STATS_ENABLED=true
#
# Phase 4.1 — Background cache snapshot recorder for backtest (audit §6 Phase 4)
SCANNER_RECORD_SNAPSHOTS=false
