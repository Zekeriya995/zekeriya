# ═══════════════════════════════════════════════════════════════
#  NEXUS PRO V10 — Proxy Server Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` (cp .env.example .env) and fill in the values.
# Never commit `.env` — it is git-ignored.

# ─── Server ────────────────────────────────────────────────────
# Port the Express proxy listens on locally. Nginx in front will
# proxy_pass https://shamcyrpto.com/api/* → http://127.0.0.1:3000/api/*
PORT=3000

# Set to "true" when running behind nginx / Cloudflare so
# express-rate-limit keys by the real client IP from X-Forwarded-For.
TRUST_PROXY=true

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call /api/*.
# A literal `*` is rejected by code — always list explicit origins.
ALLOWED_ORIGINS=https://shamcyrpto.com,https://www.shamcyrpto.com

# ─── Telegram Notifications (optional) ─────────────────────────
# Get a bot token from @BotFather, then talk to your bot once and
# call https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id.
TG_BOT_TOKEN=
TG_CHAT_ID=

# Optional shared secret for /notify. If set, the PWA must include
# the same value as `X-Notify-Secret` header. Leave empty to allow
# unauthenticated callers (rate-limit + CORS still apply).
NEXUS_NOTIFY_SECRET=
